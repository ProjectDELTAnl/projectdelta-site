# Project DELTΔ error routing voor Apache/TransIP.
ErrorDocument 404 /404.html
ErrorDocument 403 /403.html
ErrorDocument 500 /500.html

# Browsercache: HTML blijft direct herbruikbaar maar wordt altijd gerevalideerd.
# Publieke beelden hebben stabiele URLs en mogen een week lokaal blijven staan.
# Astro geeft alle bestanden onder /_astro/ een inhoudshash; die assets kunnen
# daardoor veilig een jaar immutable worden gecachet.
<IfModule mod_headers.c>
  <FilesMatch "\.(?:html?)$">
    Header always set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(?:avif|gif|ico|jpe?g|png|svg|webp)$">
    Header set Cache-Control "public, max-age=604800, stale-while-revalidate=86400"
  </FilesMatch>

  <FilesMatch "\.(?:txt|xml)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>

  <If "%{REQUEST_URI} =~ m#^/_astro/#">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </If>
</IfModule>

# Handmatige redirects voor oude of verplaatste publieke routes.
# Voeg alleen bewuste permanente redirects toe, bijvoorbeeld:
# Redirect 301 /oud-pad/ /nieuw-pad/
