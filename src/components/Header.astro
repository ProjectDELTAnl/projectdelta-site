---
import { mainNavigation } from "../data/navigation.ts";

const currentPath = Astro.url.pathname;

function resolveHref(href: string) {
  if (currentPath === "/" && href.startsWith("/#")) {
    return href.slice(1);
  }

  return href;
}
---

<header class="topbar" data-nav>
  <nav class="nav" aria-label="Hoofdnavigatie">
    <a
      class="brand"
      href={currentPath === "/" ? "#top" : "/"}
      aria-label="Project DELTΔ home"
    >
      <span class="brand-stamp-shell" aria-hidden="true">
        <img
          class="brand-stamp"
          src="/assets/delta-profielstempel-128.webp"
          alt=""
          decoding="async"
          height="128"
          width="128"
        />
      </span>
      <span class="brand-copy">
        <span>PROJECT DELTΔ</span>
        <small>Netwerk / Studie / Media</small>
      </span>
    </a>
    <div class="nav-links">
      {
        mainNavigation.map((item) => (
          <a
            class:list={{ "hide-mobile": item.hideMobile }}
            href={resolveHref(item.href)}
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>
