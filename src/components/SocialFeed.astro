---
import { publishedSocialFeedItems } from "../data/socialFeed.ts";
import type { SocialFeedItem, SocialMetricSnapshot } from "../data/types.ts";

interface Props {
  items?: SocialFeedItem[];
  limit?: number;
  emptyTitle?: string;
  emptyText?: string;
  emptyHref?: string;
  emptyLinkLabel?: string;
}

const {
  items = publishedSocialFeedItems,
  limit,
  emptyTitle = "Nog geen gecureerde feeditems.",
  emptyText = "Nieuwe signalen verschijnen hier pas na menselijke review.",
  emptyHref,
  emptyLinkLabel,
} = Astro.props;
const visibleItems = typeof limit === "number" ? items.slice(0, limit) : items;

const formatDate = (date: string) =>
  new Intl.DateTimeFormat("nl-NL", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  }).format(new Date(date));

const formatNumber = (value: number) =>
  new Intl.NumberFormat("nl-NL").format(value);

const metricLabels = [
  ["views", "Views"],
  ["likes", "Likes"],
  ["comments", "Reacties"],
  ["shares", "Gedeeld"],
] as const satisfies ReadonlyArray<
  readonly [
    keyof Pick<SocialMetricSnapshot, "views" | "likes" | "comments" | "shares">,
    string,
  ]
>;

const metricEntries = (snapshot: SocialMetricSnapshot) =>
  metricLabels.flatMap(([key, label]) => {
    const value = snapshot[key];
    return typeof value === "number" ? [{ key, label, value }] : [];
  });
---

<div class="social-feed" data-feed-count={visibleItems.length}>
  {
    visibleItems.length > 0 ? (
      <ol class="social-feed-list" aria-label="Gecureerde sociale signalen">
        {visibleItems.map((item) => (
          <li>
            <article class="social-feed-card reveal">
              {item.thumbnail ? (
                <img
                  src={item.thumbnail}
                  alt={item.thumbnailAlt ?? ""}
                  loading="lazy"
                  decoding="async"
                  class="social-feed-thumb"
                  data-aspect={item.thumbnailAspect ?? "landscape"}
                />
              ) : null}
              <div class="social-feed-body">
                <div class="social-feed-meta">
                  <span>{item.platform}</span>
                  <span>{item.type}</span>
                  <time datetime={item.publishedAt}>
                    {formatDate(item.publishedAt)}
                  </time>
                </div>
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
                {item.tags?.length ? (
                  <ul class="social-feed-tags" aria-label="Tags">
                    {item.tags.map((tag) => (
                      <li>{tag}</li>
                    ))}
                  </ul>
                ) : null}
                {item.metricsSnapshot ? (
                  <div class="social-feed-metrics">
                    <p>
                      Meetstand{" "}
                      <time datetime={item.metricsSnapshot.measuredAt}>
                        {formatDate(item.metricsSnapshot.measuredAt)}
                      </time>{" "}
                      / {item.metricsSnapshot.sourceLabel}
                    </p>
                    <dl>
                      {metricEntries(item.metricsSnapshot).map((metric) => (
                        <div>
                          <dt>{metric.label}</dt>
                          <dd>{formatNumber(metric.value)}</dd>
                        </div>
                      ))}
                    </dl>
                  </div>
                ) : null}
              </div>
              <div class="social-feed-actions">
                <a
                  class="button secondary social-feed-link"
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Open ${item.title} op ${item.platform} in een nieuw tabblad`}
                >
                  Open op {item.platform}
                  <span class="visually-hidden"> (opent in nieuw tabblad)</span>
                </a>
                {item.relatedHref && item.relatedLabel ? (
                  <a class="social-feed-related" href={item.relatedHref}>
                    {item.relatedLabel}
                  </a>
                ) : null}
              </div>
            </article>
          </li>
        ))}
      </ol>
    ) : (
      <div class="social-feed-empty reveal">
        <strong>{emptyTitle}</strong>
        <p>{emptyText}</p>
        {emptyHref && emptyLinkLabel ? (
          <a href={emptyHref}>{emptyLinkLabel}</a>
        ) : null}
      </div>
    )
  }
</div>
