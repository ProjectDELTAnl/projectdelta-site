---
import { site } from "../data/site.ts";
import { socialLinks } from "../data/socials.ts";

interface Props {
  variant?: "default" | "dossier";
  label?: string | undefined;
}

const {
  variant = "default",
  label = "NETWERK / STUDIE / MEDIA / NEDERLAND ONDER DE OPPERVLAKTE",
} = Astro.props;

const featuredSocials = socialLinks.filter((social) => social.featured);
---

<footer class:list={["footer", { "dossier-footer": variant === "dossier" }]}>
  <div class="footer-main">
    <div>
      <strong>PROJECT DELTΔ</strong>
      <span>{label}</span>
    </div>

    {
      variant === "dossier" ? (
        <p>
          <a href="/">Terug naar hoofdpagina</a> ·{" "}
          <a href="/socials/">Socials</a> · <a href="/privacy/">Privacy</a> ·{" "}
          <a href="/voorwaarden/">Voorwaarden</a> ·{" "}
          <a
            href={site.discordInvite}
            target="_blank"
            rel="noopener noreferrer"
          >
            Join de Discord
          </a>
        </p>
      ) : (
        <nav class="footer-socials" aria-label="Sociale kanalen en beleid">
          {featuredSocials.map((social) => (
            <a href={social.href} target="_blank" rel="me noopener noreferrer">
              {social.platform}
            </a>
          ))}
          <a href="/socials/">Alle kanalen</a>
          <a href="/privacy/">Privacy</a>
          <a href="/voorwaarden/">Voorwaarden</a>
        </nav>
      )
    }
  </div>
  {variant !== "dossier" && <p>Verbinding · Vorming · Productie</p>}
</footer>
