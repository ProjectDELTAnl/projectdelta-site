---
import { socialLinks } from "../data/socials.ts";
import type { SocialLink } from "../data/types.ts";

interface Props {
  links?: SocialLink[];
}

const { links = socialLinks } = Astro.props;
---

<div class="social-grid">
  {
    links.map((social) => (
      <a
        class="social-card reveal"
        href={social.href}
        target="_blank"
        rel="me noopener noreferrer"
      >
        <span class="social-platform">{social.platform}</span>
        <strong>{social.label}</strong>
        <span class="social-role">{social.role}</span>
      </a>
    ))
  }
</div>
