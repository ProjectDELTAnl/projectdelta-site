---
import { site } from "../data/site.ts";
---

<div class="discord-card reveal">
  <div class="panel-header">
    <span>DELTA NETWORK</span>
    <span class="live-dot">OPEN</span>
  </div>
  <p>
    De Discord is de eerste werkplaats voor bronnen, draadjes, studie en mediawerk.
    Openen gebeurt bewust via een externe link.
  </p>
  <a class="button secondary" href={site.discordInvite} target="_blank" rel="noopener noreferrer">
    Open Discord
  </a>
</div>
