---
import SocialGrid from "../components/SocialGrid.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Sociale kanalen - Project DELTΔ"
  description="Officiële publieke sociale kanalen van Project DELTΔ."
  canonicalPath="/socials/"
>
  <section class="page-hero section-shell">
    <p class="eyebrow">KANALEN / DISTRIBUTIE</p>
    <h1>Sociale Kanalen</h1>
    <p class="section-intro">
      Social media is distributie. De website blijft het archief. Dit zijn de
      publieke kanalen waar Project DELTΔ posts, clips, draadjes en visuals kan
      verspreiden.
    </p>
  </section>

  <section class="socials-page section-shell" aria-label="Sociale kanalen">
    <SocialGrid />
  </section>
</BaseLayout>
