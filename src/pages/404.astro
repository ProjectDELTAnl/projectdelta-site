---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Niet gevonden - Project DELTΔ"
  description="Deze Project DELTΔ-pagina bestaat niet of is verplaatst."
  canonicalPath="/404/"
>
  <section class="page-hero not-found section-shell">
    <span class="page-stamp-shell" aria-hidden="true">
      <img class="page-stamp" src="/assets/delta-profielstempel-512.png" alt="" />
    </span>
    <p class="eyebrow">404 / NIET GEVONDEN</p>
    <h1>Deze route bestaat niet.</h1>
    <p class="section-intro">
      De kaart bevat nog gaten. Ga terug naar de hoofdpagina of open het
      publicatiearchief.
    </p>
    <div class="hero-actions">
      <a class="button primary" href="/">Hoofdpagina</a>
      <a class="button secondary" href="/publicaties/">Publicaties</a>
    </div>
  </section>
</BaseLayout>
