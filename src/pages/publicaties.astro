---
import BaseLayout from "../layouts/BaseLayout.astro";
import { publications } from "../data/publications.ts";
---

<BaseLayout
  title="Publicaties - Project DELTΔ"
  description="Publicatiearchief van Project DELTΔ: essays, dossiers, analyses en toekomstige media-output."
  canonicalPath="/publicaties/"
>
  <section class="page-hero section-shell">
    <p class="eyebrow">ARCHIEF / PUBLICATIES</p>
    <h1>Publicaties</h1>
    <p class="section-intro">
      De website is het vaste geheugen van Project DELTΔ. Essays, dossiers en
      analyses komen hier terecht zodra ze publiek genoeg zijn om vindbaar te
      blijven.
    </p>
  </section>

  <section class="archive section-shell" aria-label="Publicatiearchief">
    <div class="archive-list">
      {
        publications.map((publication) => (
          <article class="archive-item reveal">
            <div>
              <p class="archive-meta">
                {publication.type} / {publication.status} /{" "}
                {publication.publishedAt}
              </p>
              <h2>{publication.title}</h2>
              <p>{publication.description}</p>
            </div>
            <a class="button secondary" href={publication.href}>
              Open {publication.type.toLowerCase()}
            </a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
