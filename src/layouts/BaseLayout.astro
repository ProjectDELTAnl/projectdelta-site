---
import "@fontsource/rajdhani/latin-500.css";
import "@fontsource/rajdhani/latin-600.css";
import "@fontsource/rajdhani/latin-700.css";
import "@fontsource/ibm-plex-mono/latin-400.css";
import "@fontsource/ibm-plex-mono/latin-500.css";
import "@fontsource/ibm-plex-mono/latin-600.css";
import "@fontsource/ibm-plex-serif/latin-400.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site.ts";
import "../styles/global.css";

interface PreloadImage {
  href: string;
  type: string;
}

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogType?: string;
  ogImage?: string;
  bodyClass?: string;
  decorations?: "home" | "dossier" | "none";
  footerVariant?: "default" | "dossier";
  footerLabel?: string;
  preloadImages?: PreloadImage[];
  robots?: string;
}

const {
  title = `${site.title} - ${site.tagline}`,
  description = site.description,
  canonicalPath = "/",
  ogType = "website",
  ogImage = site.ogImage,
  bodyClass = "",
  decorations = "home",
  footerVariant = "default",
  footerLabel,
  preloadImages = [],
  robots,
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, site.url).toString();
const imageUrl = new URL(ogImage, site.url).toString();
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#050506" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml" />
    <link
      rel="icon"
      href="/assets/favicon-192.png"
      sizes="192x192"
      type="image/png"
    />
    <link rel="apple-touch-icon" href="/assets/favicon-512.png" />
    {
      preloadImages.map(({ href, type }) => (
        <link rel="preload" as="image" href={href} type={type} />
      ))
    }
  </head>
  <body class={bodyClass}>
    <div class="site-noise" aria-hidden="true"></div>
    <div class="grid-overlay" aria-hidden="true"></div>
    {
      decorations === "home" && (
        <div class="nap-line" aria-hidden="true">
          <span>NAP 0.00 / ZEENIVEAU / SCAN ACTIEF</span>
        </div>
      )
    }
    {
      decorations === "dossier" && (
        <div class="dossier-stream" aria-hidden="true" />
      )
    }

    <Header />
    <main id="top">
      <slot />
    </main>
    <Footer variant={footerVariant} label={footerLabel} />
    <script>
      import "../scripts/reveal.ts";
    </script>
  </body>
</html>
