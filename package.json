{
  "name": "projectdelta-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Statische website voor Project DELTA.",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:map-data": "node src/scripts/generate-map-data.mjs",
    "check:map-data": "node src/scripts/generate-map-data.mjs --check",
    "generate:map-assets": "node src/scripts/generate-map-assets.mjs",
    "check:map-assets": "node src/scripts/generate-map-assets.mjs --check",
    "validate:data": "node src/scripts/validate-site-data.mjs",
    "prepare:deploy": "node src/scripts/sftp-manifest-deploy.mjs",
    "html:check": "html-validate \"dist/**/*.html\"",
    "css:check": "stylelint \"src/**/*.css\"",
    "test:deploy-plan": "node --test node-tests/deploy-manifest.test.mjs",
    "test:smoke": "playwright test",
    "check": "npm run format:check && npm run check:map-assets && npm run validate:data && npm run test:deploy-plan && npm run build && npm run html:check && npm run css:check && npm run test:smoke"
  },
  "devDependencies": {
    "@astrojs/svelte": "^9.0.0",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@fontsource/rajdhani": "^5.2.7",
    "@playwright/test": "^1.61.1",
    "astro": "^7.0.3",
    "html-validate": "^11.5.3",
    "prettier": "^3.9.3",
    "sharp": "^0.35.3",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.56.4",
    "svgo": "^4.0.1"
  }
}
