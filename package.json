{
  "name": "projectdelta-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Statische website voor Project DELTA.",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:types": "astro check",
    "lint": "eslint \"eslint.config.js\" \"astro.config.ts\" \"playwright.config.ts\" \"src/**/*.ts\" \"tests/**/*.ts\" \"node-tests/**/*.ts\"",
    "generate:map-data": "tsx src/scripts/generate-map-data.ts",
    "check:map-data": "tsx src/scripts/generate-map-data.ts --check",
    "generate:map-assets": "tsx src/scripts/generate-map-assets.ts",
    "check:map-assets": "tsx src/scripts/generate-map-assets.ts --check",
    "check:colors": "tsx src/scripts/check-color-palette.ts",
    "check:animations": "tsx src/scripts/check-animation-budget.ts",
    "validate:data": "tsx src/scripts/validate-site-data.ts",
    "prepare:deploy": "tsx src/scripts/sftp-manifest-deploy.ts",
    "html:check": "html-validate \"dist/**/*.html\"",
    "css:check": "stylelint \"src/**/*.css\"",
    "test:deploy-plan": "node --import tsx --test node-tests/deploy-manifest.test.ts",
    "test:smoke": "playwright test",
    "test:webkit": "DELTA_WEBKIT=1 playwright test --project=webkit-desktop --workers=1",
    "measure:map-performance": "tsx src/scripts/measure-map-performance.ts",
    "measure:map-performance:firefox": "DELTA_MAP_BROWSER=firefox tsx src/scripts/measure-map-performance.ts",
    "measure:map-performance:webkit": "DELTA_MAP_BROWSER=webkit tsx src/scripts/measure-map-performance.ts",
    "profile:map-performance": "tsx src/scripts/profile-map-performance.ts",
    "check": "npm run format:check && npm run check:types && npm run lint && npm run check:colors && npm run check:animations && npm run check:map-assets && npm run validate:data && npm run test:deploy-plan && npm run build && npm run html:check && npm run css:check && npm run test:smoke"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/svelte": "^9.0.0",
    "@eslint/js": "^10.0.1",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@fontsource/rajdhani": "^5.2.7",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "astro": "^7.0.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "html-validate": "^11.5.3",
    "prettier": "^3.9.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^4.1.1",
    "sharp": "^0.35.3",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.56.4",
    "svgo": "^4.0.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
